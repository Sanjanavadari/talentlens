# =============================================================================
# TalentLens — deployment environment variables
# Copy to backend/.env and frontend/.env (or set in Render / Vercel dashboards).
# =============================================================================

# --- Backend (Render / Docker) ------------------------------------------------

# SQLite (local default) or Postgres in production, e.g.:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/talentlens
DATABASE_URL=sqlite:///./talentlens.db

# Comma-separated browser origins allowed to call the API.
# Use * for local dev only. In production set your Vercel URL, e.g.:
# CORS_ORIGINS=https://talentlens.vercel.app,https://www.talentlens.vercel.app
CORS_ORIGINS=*

# JWT signing secret — generate a long random string for production
JWT_SECRET_KEY=change-me-in-production-use-env-var
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Sentence-transformers model (downloaded on first startup)
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Upload limits
MAX_UPLOAD_SIZE_MB=10
MAX_RESUMES_PER_REQUEST=50

# Optional LLM explanations (leave unset to disable)
# LLM_API_KEY=
# LLM_MODEL_NAME=claude-sonnet-4-20250514
# LLM_PROVIDER=anthropic
# LLM_TIMEOUT_SECONDS=15

# --- Frontend (Vercel) --------------------------------------------------------

# Browser-facing API base URL
# Local dev (backend on 8002):
# VITE_API_BASE_URL=http://127.0.0.1:8002/api/v1
# Production (same-origin proxy or direct backend URL):
# VITE_API_BASE_URL=https://your-backend.onrender.com/api/v1
VITE_API_BASE_URL=http://127.0.0.1:8002/api/v1

# Docker Compose only — Vite dev proxy target (not used on Vercel)
# API_PROXY_TARGET=http://backend:8000
